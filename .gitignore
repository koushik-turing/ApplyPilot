# ============================================================
#  Only SECRETS and machine-local junk are excluded.
#  Everything else (code, docs, candidates/, manikanta/, resumes,
#  Excel, seed/sponsorship data) IS committed so a collaborator
#  can see and work on the whole project.
# ============================================================

# ===== SECRETS — never commit (the one hard rule) =====
.env
**/.env
backend/.env
*.key
*_key.txt
adzuna_key.txt
secrets/
**/credentials*.json
**/token*.json

# ===== logs (noise; can contain stray keys/PII) =====
*.log
*.log.*
*.out.log
*.err.log

# ===== generated caches / temp =====
seed/live_tokens.json
data/_upload_*
**/__pycache__/
*.pyc
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# ===== OS / editor =====
.DS_Store
Thumbs.db
.vscode/
.idea/
