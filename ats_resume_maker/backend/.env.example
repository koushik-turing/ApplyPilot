# Copy this file to ".env" and fill in your key. The .env file is git-ignored.

# Your Claude API key from https://console.anthropic.com  (Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: which Claude model to use (default is the best one).
# Cheaper options: claude-sonnet-4-6  or  claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-8
